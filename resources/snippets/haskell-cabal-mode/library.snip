# key: library
# key: lib
# name: library section
# --
library${1: ${2:name}}
  import: ghc-options
  exposed-modules:
    ${3:Foo}
${4:  other-modules:
    ${5:Bar}
}${6:  hs-source-dirs:
    src
}  build-depends:
    , base >= 4.16
    , text
${7:  build-tool-depends:
    ${8:  alex:alex
    , happy:happy
    , hsc2hs:hsc2hs}
}${9:  mixins:
    -- Rename Foo -> Bar
    , ${10:`(haskell-cabal--yasnippet--current-package-name-from-cabal-file)`} hiding ( Foo )
    , $10 ( Bar as Foo )
}
