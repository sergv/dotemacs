Name: simple-attrset

=-=
{
hello =
world;

yes =
"no";

pi =
3;
}
=-=
{
  hello =
    world;

  yes =
    "no";

  pi =
    3;
}
=-=-=

Name: attrset-with-comments

=-=
{
foo = {
# foo
enable = true; #foo
bar = true;
};
}
=-=
{
  foo = {
    # foo
    enable = true; #foo
    bar = true;
  };
}
=-=-=
