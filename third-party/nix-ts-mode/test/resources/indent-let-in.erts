Name: empty-let-in

=-=
let
  in z
=-=
let
in z
=-=-=

Name: single-let-in

=-=
let
  x = y;
  in z
=-=
let
  x = y;
in z
=-=-=

Name: single-let-in-multiple-bindings

=-=
let x = y;
      v = w;
  in z
=-=
let x = y;
    v = w;
in z
=-=-=

Name: single-let-in-multiple-bindings-with-coments

=-=
let x = y; # test1
      # test2
      v = w;
  in z
=-=
let x = y; # test1
    # test2
    v = w;
in z
=-=-=


Name: nested-let-in

=-=
let
x = let
a = b;
in c;
in z
=-=
let
  x = let
        a = b;
      in c;
in z
=-=-=

Name: let-in-semicolon

=-=
let
x = let
a = b;
in
c
;
in z
=-=
let
  x = let
        a = b;
      in
      c
    ;
in z
=-=-=
